# Copy to .env and change secrets before deploying.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"

POSTA_SECRET=change-me-to-a-long-random-string
POSTA_DB_PATH=./data/posta.db
POSTA_HOST=0.0.0.0
POSTA_PORT=8000

# Platform (production)
PAKETO_ENV=production
PAKETO_ALLOW_REGISTER=0
PAKETO_HTTPS=1
PAKETO_AUTH_RATE_LIMIT=20
PAKETO_AUTH_RATE_WINDOW=300
